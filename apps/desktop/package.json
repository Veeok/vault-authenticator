{
  "name": "desktop",
  "productName": "Vault Authenticator",
  "version": "2.0.0",
  "description": "Desktop TOTP authenticator",
  "author": "Veok",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "checksums": "node ./scripts/generate-checksums.cjs",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:smoke": "vitest run src/__tests__/smoke-fixtures.test.ts src/__tests__/window-lifecycle.test.ts src/__tests__/preload.window-api.test.ts"
  },
  "build": {
    "win": {
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-addons/electron-forge-maker-nsis": "^7.0.2",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "electron": "40.6.1",
    "eslint": "^8.0.1",
    "eslint-plugin-import": "^2.25.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.12",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@authenticator/backup": "workspace:*",
    "@authenticator/core": "workspace:*",
    "@authenticator/ui": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron-store": "^11.0.2",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
